# Patient Backend (Flask)

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=chikitsak
DB_NAME=Chikitsak_DB

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# HuggingFace triage model (called via Inference API — no local download)
TRIAGE_MODEL_PATH=Nishikakansal/chikitsak-triage-model
HF_TOKEN=your_huggingface_token_here

# Server
PORT=5000

# Frontend URL (for CORS) — set to your Vercel URL on Render
FRONTEND_URL=https://chikitsakpatient.vercel.app
