# Patient Backend (Flask)

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=chikitsak
DB_NAME=Chikitsak_DB

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# HuggingFace triage model (default: Nishikakansal/chikitsak-triage-model)
TRIAGE_MODEL_PATH=Nishikakansal/chikitsak-triage-model

# Server
PORT=5000

# Windows only: path to ffmpeg.exe directory (leave blank on Linux/Render)
FFMPEG_PATH=
